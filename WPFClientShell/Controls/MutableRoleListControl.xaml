<UserControl x:Class="WPFClientShell.Controls.MutableRoleListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WPFClientShell.Controls"
             xmlns:ext="clr-namespace:WPFClientShell.Extensions"
             xmlns:modelh="clr-namespace:WPFClientShell.Model.Hub"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="300">
    <ItemsControl ItemsSource="{Binding Roles, RelativeSource={RelativeSource AncestorType=local:MutableRoleListControl}}"
                  d:ItemsSource="{ext:EnumBinding modelh:RoleVisual}">
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <local:MutableRoleListItemControl Role="{Binding .}"
                                                  QuantityChange="{Binding QuantityChangeCommand, RelativeSource={RelativeSource AncestorType=local:MutableRoleListControl}}"/>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>