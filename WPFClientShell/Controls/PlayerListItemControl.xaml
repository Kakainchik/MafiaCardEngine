<UserControl x:Class="WPFClientShell.Controls.PlayerListItemControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WPFClientShell.Controls"
             xmlns:conv="clr-namespace:WPFClientShell.Converters"
             mc:Ignorable="d"
             d:DesignHeight="100" d:DesignWidth="260">
    <UserControl.Resources>
        <conv:BoolVisibilityConverter x:Key="VisibilityConverter"/>
    </UserControl.Resources>
    <DockPanel>
        <TextBlock DockPanel.Dock="Left"
                   Text="{Binding Player, RelativeSource={RelativeSource AncestorType=local:PlayerListItemControl}}"
                   d:Text="SampleNickname"
                   VerticalAlignment="Center"
                   TextWrapping="NoWrap"
                   TextAlignment="Justify"
                   FontWeight="Bold"
                   FontSize="14">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsReady}" Value="True">
                            <Setter Property="Foreground" Value="DarkSeaGreen"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
    </DockPanel>
</UserControl>