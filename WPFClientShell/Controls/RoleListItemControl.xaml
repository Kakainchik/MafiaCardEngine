<UserControl x:Class="WPFClientShell.Controls.RoleListItemControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WPFClientShell.Controls"
             xmlns:design="clr-namespace:WPFClientShell.Controls.Design"
             xmlns:conv="clr-namespace:WPFClientShell.Converters"
             mc:Ignorable="d"
             d:DesignHeight="90" d:DesignWidth="300"
             d:DataContext="{d:DesignInstance design:MutableRoleListItemControlDesign, IsDesignTimeCreatable=True}">
    <UserControl.Resources>
        <conv:RoleColorConverter x:Key="RoleColorConverter"/>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="{Binding Role, RelativeSource={RelativeSource AncestorType=local:RoleListItemControl}}"
                   Foreground="{Binding Role, Converter={StaticResource RoleColorConverter}, RelativeSource={RelativeSource AncestorType=local:RoleListItemControl}}"
                   TextAlignment="Center"
                   VerticalAlignment="Center"
                   FontWeight="DemiBold"
                   d:Text="{Binding Role}"
                   d:Foreground="{Binding Role, Converter={StaticResource RoleColorConverter}}"/>

        <TextBlock Grid.Column="1"
                   Text="{Binding Quantity, RelativeSource={RelativeSource AncestorType=local:RoleListItemControl}}"
                   d:Text="{Binding Quantity}"
                   TextAlignment="Center"
                   VerticalAlignment="Center"/>
    </Grid>
</UserControl>