<UserControl x:Class="WPFClientShell.UI.CreateLobbyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WPFClientShell.UI"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:busy="https://github.com/moh3ngolshani/BusyIndicator"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <!-- Busy Indicator Sizes -->
        <sys:Double x:Key="IndicatorScaleX">0.3</sys:Double>
        <sys:Double x:Key="IndicatorScaleY">0.3</sys:Double>
    </UserControl.Resources>
    <StackPanel VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Width="150">
        <TextBlock Text="Game Title"
                   TextAlignment="Center"/>

        <TextBox Text="{Binding LobbyTitle, Mode=OneWayToSource, UpdateSourceTrigger=PropertyChanged}"
                 MaxLength="20"/>

        <TextBlock Text="Description"
                   TextAlignment="Center"
                   Margin="0, 15, 0, 0"/>

        <TextBox Text="{Binding LobbyDescription, Mode=OneWayToSource}"
                 MaxLength="50"/>

        <Button Content="Publish New Game"
                Margin="0, 15, 0, 0"
                IsEnabled="{Binding CanCreateLobby}"
                FontWeight="Bold"
                Command="{Binding PublishLobbyCommand}"/>

        <Button Content="Back"
                Margin="0, 15, 0, 0"
                Command="{Binding NavigateToHallCommand}"/>

        <busy:BusyMask IsBusy="{Binding IsBusy}"
                       Margin="0, 15, 0, 0"
                       IndicatorType="Ellipse"
                       BusyContent="{x:Null}"/>
    </StackPanel>
</UserControl>