<UserControl x:Class="WPFClientShell.UI.GamePanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WPFClientShell.UI"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:busy="https://github.com/moh3ngolshani/BusyIndicator"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <!-- Busy Indicator Sizes -->
        <sys:Double x:Key="IndicatorScaleX">0.3</sys:Double>
        <sys:Double x:Key="IndicatorScaleY">0.3</sys:Double>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.4*"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Column="0"
                   Grid.ColumnSpan="2">
            <Button DockPanel.Dock="Left"
                    Content="&lt;&lt; Leave"/>

            <!-- Loading Animation -->
            <busy:BusyMask DockPanel.Dock="Right"
                           IsBusy="{Binding IsBusy}"
                           IndicatorType="Ellipse"
                           BusyContent="{x:Null}"
                           BusyContentMargin="-10"/>

            <TextBlock DockPanel.Dock="Left"
                       Padding="10, 0"
                       Text="{Binding AllPlayers.Count, StringFormat=Alive players {0}}"
                       TextAlignment="Left"
                       VerticalAlignment="Center"/>
        </DockPanel>

        <ContentControl Grid.Column="0"
                        Grid.Row="1"
                        Content="{Binding Screen}"/>

        <UniformGrid Grid.Column="1"
                     Grid.Row="1"
                     Columns="1">
            <!-- Alive chat -->
            <DockPanel Visibility="{Binding AliveChatVisibility}">
                <DockPanel DockPanel.Dock="Bottom"
                           Margin="0,5,0,0">
                    <Button DockPanel.Dock="Right"
                            Content=">>"
                            Command="{Binding DropAliveMessageCommand}"/>

                    <TextBox DockPanel.Dock="Left"
                             MaxLength="100"
                             MaxLines="1"
                             Text="{Binding AliveChatMessage, Mode=TwoWay}"/>
                </DockPanel>

                <ScrollViewer VerticalScrollBarVisibility="Hidden">
                    <ItemsControl ItemsSource="{Binding AliveChatLines}"
                                  d:ItemsSource="{d:SampleData}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DataTemplate.Resources>
                                    <Style TargetType="{x:Type Grid}">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="LightBlue"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataTemplate.Resources>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!--Username Text Block-->
                                    <TextBlock Grid.Column="0"
                                               VerticalAlignment="Stretch"
                                               Margin="5,0,0,0"
                                               Text="{Binding Who, StringFormat={}{0}&gt;}"
                                               FontStyle="Italic"
                                               FontWeight="Bold"/>

                                    <!--Message Text Block-->
                                    <TextBlock Grid.Column="1"
                                               VerticalAlignment="Stretch"
                                               Margin="5,0,0,0"
                                               Text="{Binding Message}"
                                               TextWrapping="Wrap"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
            
            <!-- Dead chat -->
            <DockPanel Visibility="{Binding DeadChatVisibility}">
                <DockPanel DockPanel.Dock="Bottom"
                           Margin="0,5,0,0">
                    <Button DockPanel.Dock="Right"
                            Content=">>"
                            Command="{Binding DropDeadMessageCommand}"/>

                    <TextBox DockPanel.Dock="Left"
                             MaxLength="100"
                             MaxLines="1"
                             Text="{Binding DeadChatMessage, Mode=TwoWay}"/>
                </DockPanel>

                <ScrollViewer VerticalScrollBarVisibility="Hidden">
                    <ItemsControl ItemsSource="{Binding DeadChatLines}"
                                  d:ItemsSource="{d:SampleData}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DataTemplate.Resources>
                                    <Style TargetType="{x:Type Grid}">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="LightBlue"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataTemplate.Resources>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!--Username Text Block-->
                                    <TextBlock Grid.Column="0"
                                               VerticalAlignment="Stretch"
                                               Margin="5,0,0,0"
                                               Text="{Binding Who, StringFormat={}{0}&gt;}"
                                               FontStyle="Italic"
                                               FontWeight="Bold"/>

                                    <!--Message Text Block-->
                                    <TextBlock Grid.Column="1"
                                               VerticalAlignment="Stretch"
                                               Margin="5,0,0,0"
                                               Text="{Binding Message}"
                                               TextWrapping="Wrap"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </UniformGrid>
    </Grid>
</UserControl>