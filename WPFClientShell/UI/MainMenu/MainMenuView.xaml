<UserControl x:Class="WPFClientShell.UI.MainMenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:local="clr-namespace:WPFClientShell.UI"
             xmlns:conv="clr-namespace:WPFClientShell.Converters"
             xmlns:busy="https://github.com/moh3ngolshani/BusyIndicator"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <conv:BoolVisibilityConverter x:Key="BoolVisibilityConverter"/>
        <!-- Busy Indicator Sizes -->
        <sys:Double x:Key="IndicatorScaleX">0.3</sys:Double>
        <sys:Double x:Key="IndicatorScaleY">0.3</sys:Double>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0"
                    VerticalAlignment="Center"
                    Margin="50, 0"
                    MaxWidth="150">
            <Button Content="Public Games"
                    Command="{Binding OpenHallCommand}"
                    IsEnabled="{Binding IsAuthenticated, Mode=OneWay}"/>
        </StackPanel>

        <StackPanel Grid.Column="1"
                    VerticalAlignment="Center"
                    Margin="50, 0"
                    MaxWidth="200">
            <TextBlock Text="Account"
                       HorizontalAlignment="Center"
                       FontWeight="Bold"
                       FontSize="16"/>

            <TextBlock Text="Username"
                       HorizontalAlignment="Right"/>
            
            <TextBox Text="{Binding Username, Mode=OneWayToSource}"/>

            <TextBlock Text="Password"
                       Margin="0, 5, 0, 0"
                       HorizontalAlignment="Right"/>

            <TextBox Text="{Binding Password, Mode=OneWayToSource}"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                
                <Button Grid.Column="0"
                        Content="Login"
                        Command="{Binding LoginCommand}"
                        Margin="5"
                        FontWeight="Bold"/>

                <Button Grid.Column="1"
                        Content="Register"
                        Command="{Binding RegisterCommand}"
                        Margin="5"
                        FontWeight="Bold"/>
            </Grid>

            <TextBlock Text="{Binding AuthInfo}"
                       FontStyle="Italic"
                       TextWrapping="Wrap"/>

            <TextBlock Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolVisibilityConverter}}">
                <Run Text="You are logged in as: "/>
                <Run Text="{Binding Nickname}"
                     FontWeight="Bold"
                     d:Text="SampleNickname"/>
            </TextBlock>

            <busy:BusyMask IsBusy="{Binding IsBusy}"
                           IndicatorType="Ellipse"
                           BusyContent="{x:Null}"/>
        </StackPanel>
    </Grid>
</UserControl>