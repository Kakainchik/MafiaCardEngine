<UserControl x:Class="WPFClientShell.UI.HostWaitingRoomView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WPFClientShell.UI"
             xmlns:sys="clr-namespace:System;assembly=System"
             xmlns:ext="clr-namespace:WPFClientShell.Extensions"
             xmlns:modelh="clr-namespace:WPFClientShell.Model.Hub"
             xmlns:conv="clr-namespace:WPFClientShell.Converters"
             xmlns:cc="clr-namespace:WPFClientShell.Controls"
             xmlns:busy="https://github.com/moh3ngolshani/BusyIndicator"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.6*"
                              MaxWidth="150"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="0.8*"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!--Preferences-->
        <StackPanel Grid.Column="0"
                    Grid.Row="0"
                    Grid.RowSpan="2"
                    Orientation="Vertical"
                    Background="Moccasin">
            <TextBox Text="{Binding CurrentLobbyData.CityName, Mode=TwoWay, FallbackValue=CityName}"
                     MaxLines="1"
                     MaxLength="20"/>

            <DockPanel Margin="0, 10, 0, 0">
                <Button DockPanel.Dock="Right"
                        Content="&gt;"
                        Command="{Binding UpMaxSeatsCommand}"/>
                
                <Button DockPanel.Dock="Right"
                        Content="&lt;"
                        Command="{Binding DownMaxSeatsCommand}"/>

                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding Path=CurrentLobbyData.MaxSeats, StringFormat=Max Players: {0}}"
                           d:Text="Max Players: 10"/>
            </DockPanel>

            <TextBlock Text="Day Type"
                       Margin="0, 10, 0, 0"/>
            
            <!--
            <ComboBox ItemsSource="{ext:EnumBinding model:DayType}"
                      SelectedIndex="0"
                      SelectedItem="{Binding Path=HostSetup.DayOption}"/>
            -->

            <TextBlock Text="Night Type"
                       Margin="0, 10, 0, 0"/>
            
            <!--
            <ComboBox ItemsSource="{ext:EnumBinding model:NightType}"
                      SelectedIndex="0"
                      SelectedItem="{Binding Path=HostSetup.NightOption}"/>
            -->

            <TextBlock Text="Trial Settings"
                       Margin="0, 10, 0, 0"/>
            <ComboBox>
                <TextBlock Text="Trial Pauses Day"/>
                <TextBlock Text="Trial Defence"/>
                <TextBlock Text="Trial Time"/>
            </ComboBox>
        </StackPanel>

        <!-- Roles -->
        <ScrollViewer Grid.Column="1"
                      Grid.Row="0"
                      Padding="10,0,10,0" VerticalScrollBarVisibility="Hidden"
                      Background="AntiqueWhite">
            <cc:MutableRoleListControl Roles="{ext:EnumBinding modelh:RoleVisual}"
                                       SelectedRoles="{Binding CurrentLobbyData.Roles}"
                                       SetupChange="{Binding RoleUpdateCommand}"/>
        </ScrollViewer>

        <!-- Players -->
        <ScrollViewer Grid.Column="2"
                      Grid.Row="0"
                      Padding="10,0,0,0" VerticalScrollBarVisibility="Hidden"
                      Background="Moccasin">
            <cc:HostPlayerListControl Players="{Binding CurrentLobbyData.Players}"
                                      PlayerKickedCommand="{Binding PlayerKickedCommand}"/>
        </ScrollViewer>

        <DockPanel Grid.Column="1"
                   Grid.Row="1"
                   Grid.ColumnSpan="3"
                   LastChildFill="True"
                   Background="AliceBlue">
            <DockPanel DockPanel.Dock="Bottom"
                       Margin="0,5,0,0">
                <Button DockPanel.Dock="Right"
                        Content=">>"
                        Command="{Binding DropMessageCommand}"/>

                <TextBox DockPanel.Dock="Left"
                         MaxLength="200"
                         MaxLines="1"
                         Text="{Binding ChatText, Mode=TwoWay}"/>
            </DockPanel>

            <ScrollViewer VerticalScrollBarVisibility="Hidden">
                <ItemsControl ItemsSource="{Binding ChatLines}"
                              d:ItemsSource="{d:SampleData}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <DataTemplate.Resources>
                                <Style TargetType="{x:Type Grid}">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="LightBlue"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataTemplate.Resources>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <!--Time Text Block-->
                                <TextBlock Grid.Column="0"
                                           VerticalAlignment="Stretch"
                                           Text="{Binding DesiredTime, StringFormat={}{0:HH:mm}}"/>

                                <!--Username Text Block-->
                                <TextBlock Grid.Column="1"
                                           VerticalAlignment="Stretch"
                                           Margin="5,0,0,0"
                                           Text="{Binding Who, StringFormat={}{0}&gt;}"
                                           FontStyle="Italic"
                                           FontWeight="Bold"/>

                                <!--Message Text Block-->
                                <TextBlock Grid.Column="2"
                                           VerticalAlignment="Stretch"
                                           Margin="5,0,0,0"
                                           Text="{Binding Message}"
                                           TextWrapping="Wrap"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>

        <Button Grid.Column="0"
                Grid.Row="2"
                Margin="10"
                Content="Back"
                Command="{Binding NavigateBackCommand}"/>

        <Button Grid.Column="1"
                Grid.Row="2"
                Grid.ColumnSpan="3"
                Margin="10"
                Content="Done"
                Command="{Binding DoneCommand}"/>

        <busy:BusyMask Grid.ColumnSpan="4"
                       Grid.RowSpan="3"
                       IsBusy="{Binding IsBusy}"
                       IndicatorType="Ellipse"
                       BusyContent="{Binding BusyReason}"/>
    </Grid>
</UserControl>