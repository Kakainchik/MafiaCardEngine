<UserControl x:Class="WPFClientShell.UI.PlayerWaitingRoomView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WPFClientShell.UI"
             xmlns:sys="clr-namespace:System;assembly=System"
             xmlns:ext="clr-namespace:WPFClientShell.Extensions"
             xmlns:modelh="clr-namespace:WPFClientShell.Model.Hub"
             xmlns:conv="clr-namespace:WPFClientShell.Converters"
             xmlns:cc="clr-namespace:WPFClientShell.Controls"
             xmlns:busy="https://github.com/moh3ngolshani/BusyIndicator"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.6*"
                              MaxWidth="150"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="0.8*"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!--Preferences-->
        <StackPanel Grid.Column="0"
                    Grid.Row="0"
                    Grid.RowSpan="2"
                    Orientation="Vertical"
                    Background="Moccasin">

            <TextBlock Margin="0, 10, 0, 0"
                       Text="{Binding Path=CurrentLobbyData.MaxSeats, StringFormat=Max Players: {0}}"
                       d:Text="Max Players: 10"/>

            <TextBlock Text="Day Type"
                           Margin="0, 10, 0, 0"/>

            <TextBlock Text="Night Type"
                       Margin="0, 10, 0, 0"/>

            <TextBlock Text="Trial Settings"
                       Margin="0, 10, 0, 0"/>
        </StackPanel>

        <!-- Roles -->
        <ScrollViewer Grid.Column="1"
                      Grid.Row="0"
                      Padding="10,0,10,0" VerticalScrollBarVisibility="Hidden"
                      Background="AntiqueWhite">
            <cc:RoleListControl SelectedRoles="{Binding CurrentLobbyData.Roles}"/>
        </ScrollViewer>

        <!-- Players -->
        <ScrollViewer Grid.Column="2"
                      Grid.Row="0"
                      Padding="10,0,0,0" VerticalScrollBarVisibility="Hidden"
                      Background="Moccasin">
            <cc:PlayerListControl Players="{Binding CurrentLobbyData.Players}"/>
        </ScrollViewer>

        <DockPanel Grid.Column="1"
                   Grid.Row="1"
                   Grid.ColumnSpan="3"
                   LastChildFill="True"
                   Background="AliceBlue">
            <DockPanel DockPanel.Dock="Bottom"
                       Margin="0,5,0,0">
                <Button DockPanel.Dock="Right"
                        Content=">>"
                        Command="{Binding DropMessageCommand}"/>

                <TextBox DockPanel.Dock="Left"
                         MaxLength="200"
                         MaxLines="1"
                         Text="{Binding ChatText, Mode=TwoWay}"/>
            </DockPanel>

            <ScrollViewer VerticalScrollBarVisibility="Hidden">
                <ItemsControl ItemsSource="{Binding ChatLines}"
                              d:ItemsSource="{d:SampleData}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <DataTemplate.Resources>
                                <Style TargetType="{x:Type Grid}">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="LightBlue"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataTemplate.Resources>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!--Time Text Block-->
                                <TextBlock Grid.Column="0"
                                           VerticalAlignment="Stretch"
                                           Text="{Binding DesiredTime, StringFormat={}{0:HH:mm}}"/>

                                <!--Username Text Block-->
                                <TextBlock Grid.Column="1"
                                           VerticalAlignment="Stretch"
                                           Margin="5,0,0,0"
                                           Text="{Binding Who, StringFormat={}{0}&gt;}"
                                           FontStyle="Italic"
                                           FontWeight="Bold"/>

                                <!--Message Text Block-->
                                <TextBlock Grid.Column="2"
                                           VerticalAlignment="Stretch"
                                           Margin="5,0,0,0"
                                           Text="{Binding Message}"
                                           TextWrapping="Wrap"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>

        <Button Grid.Column="0"
                Grid.Row="2"
                Margin="10"
                Content="Leave"
                Command="{Binding NavigateBackCommand}"/>

        <Button Grid.Column="1"
                Grid.Row="2"
                Grid.ColumnSpan="3"
                Margin="10"
                Content="Ready \ Not Ready"
                Command="{Binding ReadyCommand}">
            <Button.Style>
                <Style TargetType="{x:Type Button}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsReady}" Value="True">
                            <Setter Property="Background" Value="GreenYellow"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>

        <busy:BusyMask Grid.ColumnSpan="4"
                       Grid.RowSpan="3"
                       IsBusy="{Binding IsBusy}"
                       IndicatorType="Ellipse"
                       BusyContent="{Binding BusyReason}"/>
    </Grid>
</UserControl>